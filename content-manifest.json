{
  "site": {
    "name": "Source Learning Lab",
    "charter": "pages/charter.html",
    "dashboard": "pages/dashboard.html",
    "search": "pages/search.html",
    "rule": "The site is organized as four first-class modules: pi-agent, mini-agent, cesium, and openlayers. Common pages stay in pages/. Old pages URLs are compatibility redirects."
  },
  "moduleConvention": {
    "moduleRoot": "modules/{module-slug}/",
    "exampleRoot": "examples/{module-slug}/",
    "required": [
      "charter.html",
      "index.html"
    ],
    "recommended": [
      "debugging.html",
      "glossary.html",
      "labs.html",
      "render-path.html",
      "roadmap.html"
    ]
  },
  "modules": [
    {
      "slug": "pi-agent",
      "name": "Pi Agent",
      "root": "modules/pi-agent/",
      "charter": "modules/pi-agent/charter.html",
      "entry": "modules/pi-agent/index.html",
      "purpose": "Understand the Pi open-source agent architecture and key source code.",
      "pages": [
        "index.html",
        "architecture.html",
        "lifecycle.html",
        "prompt-processing.html",
        "tools.html",
        "sessions.html",
        "models.html",
        "frontend.html",
        "design-tradeoffs.html",
        "labs.html",
        "pi-debugging.html",
        "glossary.html",
        "callgraph.html",
        "faq.html"
      ]
    },
    {
      "slug": "mini-agent",
      "name": "Mini Agent",
      "root": "modules/mini-agent/",
      "charter": "modules/mini-agent/charter.html",
      "entry": "modules/mini-agent/index.html",
      "purpose": "Build a minimal agent from scratch and learn model API compatibility.",
      "pages": [
        "index.html",
        "model-api.html",
        "roadmap.html"
      ]
    },
    {
      "slug": "cesium",
      "name": "Cesium",
      "root": "modules/cesium/",
      "charter": "modules/cesium/charter.html",
      "entry": "modules/cesium/index.html",
      "purpose": "Understand the 3D rendering path from Viewer to GPU.",
      "pages": [
        "index.html",
        "render-path.html",
        "debugging.html",
        "glossary.html"
      ]
    },
    {
      "slug": "openlayers",
      "name": "OpenLayers",
      "root": "modules/openlayers/",
      "charter": "modules/openlayers/charter.html",
      "entry": "modules/openlayers/index.html",
      "purpose": "Understand the 2D map rendering path from Map/View/Layer/Source to Canvas/WebGL.",
      "pages": [
        "index.html",
        "render-path.html",
        "debugging.html"
      ]
    }
  ],
  "commonPages": [
    "pages/dashboard.html",
    "pages/charter.html",
    "pages/search.html",
    "pages/knowledge-check.html"
  ]
}
